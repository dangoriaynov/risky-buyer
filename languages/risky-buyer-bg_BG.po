msgid "Uncollected shipment"
msgstr "Неизкупена пратка"

msgid "Fake order"
msgstr "Фалшива поръчка"

msgid "Problematic / abusive"
msgstr "Проблемен / обиди"

msgid "Other"
msgstr "Друго"

msgid "You do not have permission to add."
msgstr "Нямате права да добавяте."

msgid "A valid phone or name is required."
msgstr "Трябва валиден телефон или име."

msgid "Only an administrator can edit."
msgstr "Само администратор може да редактира."

msgid "Only an administrator can delete."
msgstr "Само администратор може да трие."

msgid "You do not have permission."
msgstr "Нямате права."

msgid "Client marked."
msgstr "Клиентът е маркиран."

msgid "Missing identifier."
msgstr "Липсва идентификатор."

msgid "Marker removed."
msgstr "Маркировката е премахната."

msgid "Remove this client from the list?"
msgstr "Да премахна ли този клиент от списъка?"

msgid "An error occurred."
msgstr "Възникна грешка."

msgid "Database write error."
msgstr "Грешка при запис в базата."

msgid "Risky buyer"
msgstr "Проблемен клиент"

msgid "Added by:"
msgstr "Добавил:"

msgid "Remove from list"
msgstr "Премахни от списъка"

msgid "Only an administrator can remove."
msgstr "Само администратор може да премахне."

msgid "Mark this client as problematic (by name and phone from the order)."
msgstr "Маркирай този клиент като проблемен (по име и телефон от поръчката)."

msgid "Reason"
msgstr "Причина"

msgid "Note (optional)"
msgstr "Бележка (по избор)"

msgid "Mark client"
msgstr "Маркирай клиента"

msgid "You do not have permission to mark clients."
msgstr "Нямате права да маркирате клиенти."

msgid "Risky buyers"
msgstr "Проблемни клиенти"

msgid "Client added to the list."
msgstr "Клиентът е добавен в списъка."

msgid "Added: %1$d · skipped (already in list): %2$d · invalid: %3$d"
msgstr "Добавени: %1$d · пропуснати (вече в списъка): %2$d · невалидни: %3$d"

msgid "Entry updated."
msgstr "Записът е обновен."

msgid "Entry removed."
msgstr "Записът е премахнат."

msgid "Check"
msgstr "Проверка"

msgid "List"
msgstr "Списък"

msgid "Add"
msgstr "Добавяне"

msgid "Enter a phone and/or name (e.g. when a client calls) to check whether they are in the list. Partial matches are shown too, newest first."
msgstr "Въведете телефон и/или име (напр. когато клиент се обади), за да проверите дали е в списъка. Частичните съвпадения също се показват, най-новите отгоре."

msgid "Phone"
msgstr "Телефон"

msgid "Name"
msgstr "Име"

msgid "Look up"
msgstr "Провери"

msgid "YES — this client is in the list"
msgstr "ДА — този клиент е в списъка"

msgid "No exact match"
msgstr "Няма точно съвпадение"

msgid "Not found by exact phone/name. Check the possible matches below."
msgstr "Не е намерен по точен телефон/име. Проверете възможните съвпадения по-долу."

msgid "Possible matches (for manual verification)"
msgstr "Възможни съвпадения (за ръчна проверка)"

msgid "Note"
msgstr "Бележка"

msgid "Source"
msgstr "Източник"

msgid "Added by"
msgstr "Добавил"

msgid "Edit entry"
msgstr "Редакция на запис"

msgid "Add one client"
msgstr "Добавяне на един клиент"

msgid "Save changes"
msgstr "Запази промените"

msgid "Add client"
msgstr "Добави"

msgid "Cancel"
msgstr "Отказ"

msgid "Bulk add"
msgstr "Пакетно добавяне"

msgid "One client per line. Fields separated by comma / tab / semicolon. A value with 6+ digits is treated as the phone, the rest as the name. The reason and note apply to the whole list. Existing entries (by phone or name) are skipped."
msgstr "Един клиент на ред. Полета, разделени със запетая / табулация / точка и запетая. Стойност с 6+ цифри се приема за телефон, останалото — за име. Причината и бележката се прилагат за целия списък. Вече съществуващи (по телефон или име) се пропускат."

msgid "Add in bulk"
msgstr "Добави пакетно"

msgid "Search (name, phone, note)"
msgstr "Търсене (име, телефон, бележка)"

msgid "All reasons"
msgstr "Всички причини"

msgid "Filter"
msgstr "Филтрирай"

msgid "Date"
msgstr "Дата"

msgid "Actions"
msgstr "Действия"

msgid "No entries."
msgstr "Няма записи."

msgid "Edit"
msgstr "Редактирай"

msgid "Remove this entry?"
msgstr "Да премахна ли този запис?"

msgid "Delete"
msgstr "Изтрий"

msgid "Settings"
msgstr "Настройки"

msgid "Synchronization"
msgstr "Синхронизация"

msgid "Synchronization with the central server"
msgstr "Синхронизация с централния сървър"

msgid "Enable sync with the central server"
msgstr "Включи синхронизация с централния сървър"

msgid "When enabled, your checks are extended with phone numbers from the shared server (created by other sites). Your own entries always stay on your site. Disable to use the local list only."
msgstr "Когато е включено, проверките се разширяват с телефони от споделения сървър (създадени от други сайтове). Вашите записи винаги остават на вашия сайт. Изключете, за да ползвате само локалния списък."

msgid "Data sent to the server (only if you have a write key): phone, name, reason, note, and your site domain."
msgstr "Данни, изпращани към сървъра (само ако имате ключ за запис): телефон, име, причина, бележка и домейна на сайта ви."

msgid "Server URL"
msgstr "URL на сървъра"

msgid "API key"
msgstr "API ключ"

msgid "Only needed to write your entries to the server. Reading the shared list is open."
msgstr "Нужен е само за запис на вашите записи към сървъра. Четенето на споделения списък е отворено."

msgid "Save settings"
msgstr "Запази настройките"

msgid "Status"
msgstr "Състояние"

msgid "Last sync:"
msgstr "Последна синхронизация:"

msgid "Cached entries:"
msgstr "Записи в кеша:"

msgid "Last error:"
msgstr "Последна грешка:"

msgid "never"
msgstr "никога"

msgid "Sync now"
msgstr "Синхронизирай сега"

msgid "Push my list to the server"
msgstr "Изпрати моя списък към сървъра"

msgid "Settings saved."
msgstr "Настройките са запазени."

msgid "Only an administrator can change settings."
msgstr "Само администратор може да променя настройките."

msgid "Sync done: %d entries cached."
msgstr "Синхронизацията завърши: %d записа в кеша."

msgid "Sync error: %s"
msgstr "Грешка при синхронизация: %s"

msgid "Pushed %d entries to the server."
msgstr "Изпратени %d записа към сървъра."

msgid "Push error: %s"
msgstr "Грешка при изпращане: %s"

msgid "Sync is disabled."
msgstr "Синхронизацията е изключена."

msgid "An API key is required to write to the server."
msgstr "Нужен е API ключ за запис към сървъра."

msgid "Combine criteria"
msgstr "Комбиниране на критериите"

msgid "All (AND)"
msgstr "Всички (AND)"

msgid "Any (OR)"
msgstr "Поне едно (OR)"

msgid "Saving…"
msgstr "Запазване…"

msgid "Saved"
msgstr "Запазено"

msgid "Checking…"
msgstr "Проверка…"

msgid "Invalid or unreachable key"
msgstr "Невалиден или недостъпен ключ"

msgid "Clients (one per line)"
msgstr "Клиенти (по един на ред)"

msgid "Fields separated by comma / tab / semicolon. A value with 6+ digits is treated as the phone, the rest as the name. The reason and note below apply to the whole list. Existing entries (by phone or name) are skipped."
msgstr "Полета, разделени със запетая / табулация / точка и запетая. Стойност с 6+ цифри се приема за телефон, останалото — за име. Причината и бележката по-долу се прилагат за целия списък. Вече съществуващи (по телефон или име) се пропускат."

msgid "Showing"
msgstr "Показани"

msgid "Clear"
msgstr "Изчисти"

msgid "No matches for the current filter."
msgstr "Няма съвпадения за текущия филтър."

msgid "Last update from the shared list:"
msgstr "Последно обновяване от общия списък:"

msgid "Phone numbers downloaded:"
msgstr "Изтеглени телефони:"

msgid "Data sent to the server: phone, name, reason, note, and your site domain."
msgstr "Данни, изпращани към сървъра: телефон, име, причина, бележка и домейна на сайта ви."

msgid "Other orders from this buyer:"
msgstr "Други поръчки от този клиент:"

msgid "Clear key"
msgstr "Изчисти ключа"

msgid "New in last sync:"
msgstr "Нови при последната синхронизация:"

msgid "Sync done: %1$d new (%2$d total downloaded)."
msgstr "Синхронизацията завърши: %1$d нови (%2$d общо изтеглени)."

msgid "Find a customer from your orders"
msgstr "Намери клиент от поръчките"

msgid "Type a name or phone…"
msgstr "Въведи име или телефон…"

msgid "Pick someone who already ordered to fill in the name and phone below."
msgstr "Изберете клиент, който вече е поръчвал, за да попълните името и телефона по-долу."

msgid "No matching customers."
msgstr "Няма съвпадащи клиенти."

msgid "Invalid key"
msgstr "Невалиден ключ"

msgid "Server unreachable — the key was not checked."
msgstr "Сървърът е недостъпен — ключът не е проверен."
